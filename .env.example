# MongoDB Atlas (required)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=HerbaGuard
MONGODB_DB_NAME=herbaguard

# Gemini orchestration (optional)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=15

# Local/test helpers (optional)
MONGODB_USE_MOCK=0
HERBAGUARD_STATIC_DIR=frontend
